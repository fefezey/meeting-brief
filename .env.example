# Bu dosya bir ŞABLONDUR — kopyalayıp ".env" adıyla kaydet ve doldur.
# .env dosyası git'e girmez (.gitignore içinde), anahtarların güvende kalır.

# ---------------------------------------------------------------
# Anthropic (Claude) — İKİ SEÇENEK VAR, birini kullanman yeterli
# ---------------------------------------------------------------
#
# SEÇENEK 1 (önerilen): OAuth — bu dosyaya hiçbir şey yazmazsın
#   Terminalde bir kez:  ant auth login
#   Kimlik bilgisi ~/.config/anthropic/ altında saklanır, otomatik
#   yenilenir ve proje klasörüne hiç girmez. Kazayla commit'lenemez.
#
# SEÇENEK 2: klasik API anahtarı — aşağıya yapıştır
#   console.anthropic.com adresinden alınır.
ANTHROPIC_API_KEY=

# İkisi de yoksa uygulama ÖRNEK VERİ modunda çalışır ve bunu
# arayüzde bir uyarıyla belirtir.

# Anahtar dolu olsa bile örnek veri kullanmak istersen:
# USE_MOCK_AI=true

# Örnek veri modunda yapay gecikme (milisaniye).
# "Analiz ediliyor..." ekranını test etmek için yükseltebilirsin.
# Varsayılan: 800
# MOCK_DELAY_MS=8000

# ---------------------------------------------------------------
# Supabase (henüz kullanılmıyor — veriler şimdilik .data/ klasöründe)
# ---------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
